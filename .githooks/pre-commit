#!/bin/bash
# Moni 预提交钩子
# 1. 拦截超过 500 行的源文件
# 2. 对暂存的 Rust 文件跑 cargo fmt --check / clippy
# 3. 对暂存的 Kotlin 文件跑 ./gradlew detekt（仅当 detekt 已注册）
#
# 工具不可用时自动跳过（向后兼容）。
# 如需绕过：git commit --no-verify（紧急情况且自负责）。

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

MAX_LINES=500
ALL_STAGED=$(git diff --cached --name-only --diff-filter=ACM)
STAGED_SOURCE_FILES=$(printf '%s\n' "$ALL_STAGED" | grep -E '\.(rs|kt|gradle\.kts)$' || true)

# ----- 第 1 段：500 行硬上限 -----
if [ -n "$STAGED_SOURCE_FILES" ]; then
    VIOLATIONS=()
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        if [ -f "$file" ]; then
            LINE_COUNT=$(wc -l < "$file")
            if [ "$LINE_COUNT" -gt "$MAX_LINES" ]; then
                VIOLATIONS+=("$file: $LINE_COUNT 行 (上限 $MAX_LINES 行)")
            fi
        fi
    done <<< "$STAGED_SOURCE_FILES"

    if [ ${#VIOLATIONS[@]} -gt 0 ]; then
        echo ""
        echo "提交被拦截：以下文件超过 $MAX_LINES 行上限"
        echo "================================================"
        for v in "${VIOLATIONS[@]}"; do
            echo "  $v"
        done
        echo "================================================"
        echo "请在提交前拆分这些文件。参考 docs/code-style.md 中的拆分指引。"
        echo ""
        exit 1
    fi
fi

# ----- 第 2 段：Rust 增量检查 -----
RUST_STAGED=$(printf '%s\n' "$ALL_STAGED" | grep -E '\.rs$' || true)
if [ -n "$RUST_STAGED" ]; then
    if command -v cargo >/dev/null 2>&1 && [ -f "Cargo.toml" ]; then
        echo "[pre-commit] cargo fmt --all -- --check ..."
        if ! cargo fmt --all -- --check; then
            echo ""
            echo "Rust 格式化未通过。请运行：cargo fmt"
            exit 1
        fi

        echo "[pre-commit] cargo clippy --workspace --all-targets ..."
        if ! cargo clippy --workspace --all-targets --quiet -- -D warnings; then
            echo ""
            echo "Rust clippy 检查未通过。修复警告后再提交。"
            exit 1
        fi
    else
        echo "[pre-commit] 跳过 Rust 检查（cargo 不可用或非 cargo 项目）"
    fi
fi

# ----- 第 3 段：Kotlin 增量检查 -----
KOTLIN_STAGED=$(printf '%s\n' "$ALL_STAGED" | grep -E '\.(kt|kts)$' || true)
if [ -n "$KOTLIN_STAGED" ]; then
    if [ -x "./gradlew" ]; then
        # 通过 grep 检测 detekt 是否注册（比 ./gradlew tasks 快几个数量级）
        DETEKT_PATTERN='alias(libs\.plugins\.detekt)\|id("dev\.detekt")\|id("io\.gitlab\.arturbosch\.detekt")'
        if grep -qE "$DETEKT_PATTERN" build.gradle.kts android/build.gradle.kts android/*/build.gradle.kts 2>/dev/null; then
            echo "[pre-commit] ./gradlew detekt ..."
            if ! ./gradlew detekt --no-configuration-cache --quiet; then
                echo ""
                echo "Kotlin detekt 检查未通过。修复 issue 或运行：./gradlew detekt --auto-correct"
                exit 1
            fi
        else
            echo "[pre-commit] 跳过 detekt（任务未注册）"
        fi
    else
        echo "[pre-commit] 跳过 Kotlin 检查（./gradlew 不可用）"
    fi
fi

exit 0
